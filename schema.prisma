  role                               Role?               @relation("User_role", fields: [roleId], references: [id])
  roleId                             String?             @map("role")
  membership                         Membership?         @relation("Membership_member")
  payments                           MembershipPayment[] @relation("MembershipPayment_member")
  stripeCustomerId                   String              @default("")
  phone                              String              @default("")
  emergencyContact                   String              @default("")
  onboardingStatus                   String              @default("not_started")
  createdAt                          DateTime            @default(now())
  updatedAt                          DateTime            @default(now()) @updatedAt
  passwordResetToken                 String?
  passwordResetIssuedAt              DateTime?
  passwordResetRedeemedAt            DateTime?
  from_Member_user                   Member[]            @relation("Member_user")
  from_MembershipPayment_processedBy MembershipPayment[] @relation("MembershipPayment_processedBy")
  from_AttendanceRecord_markedBy     AttendanceRecord[]  @relation("AttendanceRecord_markedBy")
  from_Instructor_user               Instructor[]        @relation("Instructor_user")

  @@index([roleId])
}

